# --- Moca Hub ---
# URL dell'Hub (usato dall'SDK per validare i launch token).
VITE_MOCA_HUB_URL=https://moca-central-hub.netlify.app

# --- Supabase (STESSA istanza dell'Hub) ---
# Necessari SOLO se l'app legge/scrive tabelle Supabase direttamente.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>

# --- Solo Netlify Functions (server-side, MAI esposte al browser) ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# --- Sviluppo locale (Mock Mode) ---
# Chiavi di test iniettate nel mock. NON committare valori reali.
VITE_DEV_OPENAI_API_KEY=
