# ── Moca Hub integration ─────────────────────────────────────────────────────
# Base URL of the Moca Hub the SDK validates launch tokens against.
NEXT_PUBLIC_MOCA_HUB_URL=https://moca-central-hub.netlify.app

# ── AI (Claude) ──────────────────────────────────────────────────────────────
# In production the per-client ANTHROPIC_API_KEY is provided by the Moca Hub
# (moca.getConfig) and forwarded to the API routes — do NOT hardcode it.
# This server env is only a LOCAL fallback for development.
ANTHROPIC_API_KEY=sk-ant-...
# Optional: override the model (defaults to claude-opus-4-8)
# ANTHROPIC_MODEL=claude-opus-4-8

# ── Supabase (reuse the Moca Hub project) ───────────────────────────────────
# Server-side only (used by the persistence API routes). Same names as the Hub
# functions. Leave empty to disable persistence (the editor still works with
# localStorage).
# SUPABASE_URL=https://YOUR-HUB-PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
