# ── Moca Hub ─────────────────────────────────────────────────────────────────
VITE_MOCA_HUB_URL=https://moca-central-hub.netlify.app

# ── Supabase (shared Moca Hub instance — anon key only) ──────────────────────
# Enables saving/loading projects under RLS. Leave empty for localStorage-only.
VITE_SUPABASE_URL=https://YOUR-HUB-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ── Local dev only (Mock Mode) ───────────────────────────────────────────────
# Personal Anthropic key used by the AI proxy when developing on localhost.
# In production the per-client ANTHROPIC_API_KEY comes from the Hub. NEVER commit.
VITE_DEV_ANTHROPIC_API_KEY=
