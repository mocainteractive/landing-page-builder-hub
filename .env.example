# ── AI (Claude) ────────────────────────────────────────────────────────────
# Required for brand extraction and AI block edits.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model (defaults to claude-opus-4-8)
# ANTHROPIC_MODEL=claude-opus-4-8

# ── Supabase (optional) ──────────────────────────────────────────────────────
# When set, the editor saves/loads projects from Supabase instead of (only)
# localStorage. Leave empty to run fully client-side.
# Browser-exposed (safe, anon key is RLS-protected):
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Server-only (NEVER expose): used by API routes for privileged operations.
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
